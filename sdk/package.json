{
  "name": "@interchained/vision-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Interchained Vision API",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.8.6"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
